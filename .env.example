# === Apex Configuration ===

# Application
APP_NAME=Apex
APP_VERSION=1.0.0
DEBUG=false
ENVIRONMENT=development

# Database (PostgreSQL + asyncpg)
DATABASE_URL=postgresql+asyncpg://apex:apex@localhost:5432/apex
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_ECHO=false

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=10

# Alpaca API
ALPACA_API_KEY=your-alpaca-api-key
ALPACA_SECRET_KEY=your-alpaca-secret-key
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# OpenAI
OPENAI_API_KEY=your-openai-api-key

# LLM Settings
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.1
LLM_DAILY_BUDGET_USD=5.0
LLM_MAX_TOKENS=4096

# LLM Provider (optional — defaults to OpenAI)
# LLM_PROVIDER=openai
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3

# Embedding (only needed for pgvector RAG in server mode)
# EMBEDDING_MODEL=nomic-embed-text-v2
# EMBEDDING_DIM=768

# LangSmith (Agent Tracing & Evaluation)
LANGCHAIN_API_KEY=your-langsmith-api-key
LANGSMITH_TRACING=true
LANGCHAIN_PROJECT="apex"
LANGSMITH_ENDPOINT=https://eu.api.smith.langchain.com

# Observability
OTEL_SERVICE_NAME=apex
OTEL_EXPORTER_ENDPOINT=http://localhost:4317
LOG_LEVEL=INFO
LOG_FORMAT=json

# Server
HOST=0.0.0.0
PORT=8000
WORKERS=1
